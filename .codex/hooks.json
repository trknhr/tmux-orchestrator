{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/zsh \"$(git rev-parse --show-toplevel)/.codex/hooks/tmux_orchestrator_events.sh\"",
            "statusMessage": "Checking tmux-orchestrator events",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/zsh \"$(git rev-parse --show-toplevel)/.codex/hooks/tmux_orchestrator_events.sh\"",
            "statusMessage": "Checking tmux-orchestrator events",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
